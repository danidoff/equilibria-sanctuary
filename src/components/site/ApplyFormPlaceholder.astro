---
interface Props {
  title?: string;
  intro?: string;
  embedUrl?: string;
}

const {
  title = 'Apply for the Experience.',
  intro = 'We review each application with care. This area is ready for a Google Form embed as the final step.',
  embedUrl,
} = Astro.props;
---

<section id="begin" class="section-pad">
  <div class="max-w">
    <div class="apply-inner">
      <div class="eyebrow center reveal" style="justify-content:center">Begin Here</div>
      <h2 class="reveal" set:html={title} />
      <p class="lead reveal">{intro}</p>
    </div>

    <div class="apply-grid reveal">
      <div class="apply-copy-card">
        <div class="apply-copy-eyebrow">Private Application</div>
        <h3>Tell us where you are, before we design what comes next.</h3>
        <p class="body-text">
          This first conversation helps us understand your current season, your level of
          depletion, and the kind of retreat experience that would genuinely support you.
        </p>
        <div class="apply-copy-points">
          <div class="apply-copy-point">
            <strong>Carefully reviewed</strong>
            <span>Every application is read with attention before we respond.</span>
          </div>
          <div class="apply-copy-point">
            <strong>Confidential by default</strong>
            <span>Your responses stay private and are used only to guide the experience.</span>
          </div>
          <div class="apply-copy-point">
            <strong>Curated fit</strong>
            <span>We only invite guests we believe we can truly serve well.</span>
          </div>
        </div>
        <div class="apply-copy-note">
          Response window: within 48 hours for the current test flow.
        </div>
      </div>

      {
        embedUrl ? (
          <div class="form-embed-shell">
            <iframe
              src={embedUrl}
              title="Equilibria Sanctuary application form"
              loading="lazy"
              class="form-embed-frame"
              frameborder="0"
              marginheight="0"
              marginwidth="0"
            ></iframe>
          </div>
        ) : (
          <div class="form-embed-shell">
            <div class="form-embed-placeholder">
              <div class="form-embed-label">Google Form Placeholder</div>
              <h3>Embed ready</h3>
              <p class="body-text">
                We will replace this placeholder with your Google Form iframe once you send the
                final form URL.
              </p>
              <div class="form-embed-checklist">
                <span>Responsive container prepared</span>
                <span>Visual style matched to the current site</span>
                <span>Ready for the final embed step</span>
              </div>
            </div>
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .apply-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.9fr) minmax(0, 1.35fr);
    gap: 28px;
    align-items: stretch;
    margin-top: 60px;
  }

  .apply-copy-card {
    padding: 44px 36px;
    background: linear-gradient(180deg, rgba(245, 237, 214, 0.72), rgba(250, 248, 242, 0.96));
    border: 1px solid rgba(201, 169, 110, 0.24);
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .apply-copy-eyebrow {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.34em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .apply-copy-card h3 {
    margin-bottom: 0;
    font-size: 2rem;
    line-height: 1.12;
  }

  .apply-copy-points {
    display: grid;
    gap: 16px;
  }

  .apply-copy-point {
    padding-top: 16px;
    border-top: 1px solid rgba(201, 169, 110, 0.2);
    display: grid;
    gap: 8px;
  }

  .apply-copy-point strong {
    font-family: var(--font-body);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-primary);
  }

  .apply-copy-point span,
  .apply-copy-note {
    font-family: var(--font-body);
    font-size: 0.74rem;
    line-height: 1.9;
    letter-spacing: 0.03em;
    color: var(--text-secondary);
  }

  .form-embed-shell {
    background: var(--white);
    border: 1px solid rgba(201, 169, 110, 0.2);
    min-height: 724px;
    overflow: hidden;
  }

  .form-embed-frame {
    display: block;
    width: 100%;
    min-height: 724px;
    border: 0;
    background: var(--white);
  }

  .form-embed-placeholder {
    min-height: 640px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    gap: 20px;
    padding: 56px;
    background:
      linear-gradient(135deg, rgba(245, 237, 214, 0.45), rgba(250, 248, 242, 0.95)),
      radial-gradient(circle at top right, rgba(201, 169, 110, 0.12), transparent 35%);
  }

  .form-embed-label {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .form-embed-placeholder h3 {
    margin-bottom: 0;
  }

  .form-embed-checklist {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .form-embed-checklist span {
    font-family: var(--font-body);
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border: 1px solid rgba(201, 169, 110, 0.3);
    color: var(--text-secondary);
    padding: 10px 14px;
    background: rgba(253, 252, 248, 0.8);
  }

  @media (max-width: 1024px) {
    .apply-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .apply-copy-card {
      padding: 36px 28px;
    }
  }

  @media (max-width: 640px) {
    .form-embed-shell,
    .form-embed-frame,
    .form-embed-placeholder {
      min-height: 620px;
    }

    .apply-copy-card,
    .form-embed-placeholder {
      padding: 32px 24px;
    }

    .apply-copy-card h3 {
      font-size: 1.7rem;
    }
  }
</style>
