---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/site/PageHero.astro';
import aboutSection from '../content/about-section.html?raw';
---

<BaseLayout
  title="About | Equilibria Sanctuary"
  description="Learn the story, philosophy, and intention behind Equilibria Sanctuary."
  pathname="/about"
>
  <PageHero eyebrow="About" secondaryHref="#about" secondaryLabel="Discover More">
    <h1 class="hero-title">
      <span class="hero-title-line">Built by those who</span>
      <span class="hero-title-line">needed it <em>most.</em></span>
    </h1>
    <p class="hero-sub">Equilibria Sanctuary was not conceived in a boardroom. It was born in the aftermath of burnout, of achieving everything and feeling nothing.</p>
  </PageHero>

  <Fragment set:html={aboutSection} />
</BaseLayout>
