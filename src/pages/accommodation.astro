---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/site/PageHero.astro';
import accommodationSection from '../content/accommodation-section.html?raw';
---

<BaseLayout
  title="Accommodation | Equilibria Sanctuary"
  description="Discover the private residence, suite experience, and design philosophy behind Equilibria Sanctuary."
  pathname="/accommodation"
>
  <PageHero eyebrow="Accommodation" secondaryHref="#accommodation" secondaryLabel="Discover More">
    <h1 class="hero-title">
      <span class="hero-title-line">Your Private</span>
      <span class="hero-title-line"><em>Sanctuary.</em></span>
    </h1>
    <p class="hero-sub">This is not a hotel. This is a home &mdash; considered in every detail, alive with quiet luxury. Each retreat is hosted in a carefully selected luxury villa, tailored to the size and energy of your group.</p>
  </PageHero>

  <Fragment set:html={accommodationSection} />
</BaseLayout>
