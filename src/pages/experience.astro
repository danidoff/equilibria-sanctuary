---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/site/PageHero.astro';
import experienceSection from '../content/experience-section.html?raw';
---

<BaseLayout
  title="The Experience | Equilibria Sanctuary"
  description="Explore the daily rhythm, rituals, and restorative structure of the Equilibria Sanctuary retreat experience."
  pathname="/experience"
>
  <PageHero eyebrow="The Experience" secondaryHref="#experience" secondaryLabel="Discover More">
    <h1 class="hero-title">
      <span class="hero-title-line">Every hour is</span>
      <span class="hero-title-line">intentionally <em>designed.</em></span>
    </h1>
    <p class="hero-sub">From the first breath of morning to the soft close of evening, each moment serves your restoration.</p>
  </PageHero>

  <Fragment set:html={experienceSection} />
</BaseLayout>
