---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import HomeSections from '../components/home/HomeSections.astro';
import ApplyFormPlaceholder from '../components/site/ApplyFormPlaceholder.astro';

const testGoogleFormUrl =
  'https://docs.google.com/forms/d/e/1FAIpQLSeKTbUF0DFc0xOfpiRCHMBvYKNk6bNMpMm_8OZ69o0NhNPeVA/viewform?embedded=true';
---

<BaseLayout
  title="Equilibria Sanctuary | Ultra-Luxury Retreat, Romania"
  description="An ultra-exclusive holistic retreat experience near Brasov, Romania. For those who seek stillness, clarity, and transformation."
  pathname="/"
>
  <HeroSection />
  <HomeSections />
  <ApplyFormPlaceholder
    title="Apply for the <em>Experience.</em>"
    intro="We curate each retreat carefully. This same test Google Form is embedded here as the homepage application section as well."
    embedUrl={testGoogleFormUrl}
  />
</BaseLayout>
