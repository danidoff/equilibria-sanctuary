---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/site/PageHero.astro';
import pricingSection from '../content/pricing-section.html?raw';
---

<BaseLayout
  title="Pricing | Equilibria Sanctuary"
  description="View the experience tiers and private retreat formats available through Equilibria Sanctuary."
  pathname="/pricing"
>
  <PageHero eyebrow="Pricing" secondaryHref="#pricing" secondaryLabel="Discover More">
    <h1 class="hero-title">
      <span class="hero-title-line">By application.</span>
      <span class="hero-title-line">By <em>invitation.</em></span>
    </h1>
    <p class="hero-sub">Each experience is curated to the individual. The investment reflects the depth of access and service.</p>
  </PageHero>

  <Fragment set:html={pricingSection} />
</BaseLayout>
