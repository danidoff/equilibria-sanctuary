---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/site/PageHero.astro';
import wellnessSection from '../content/wellness-section.html?raw';
---

<BaseLayout
  title="Wellness | Equilibria Sanctuary"
  description="Explore the therapeutic pillars, holistic support, and restorative rituals at Equilibria Sanctuary."
  pathname="/wellness"
>
  <PageHero eyebrow="Wellness" secondaryHref="#wellness" secondaryLabel="Discover More">
    <h1 class="hero-title">
      <span class="hero-title-line">Not a reset.</span>
      <span class="hero-title-line">A <em>recalibration.</em></span>
    </h1>
    <p class="hero-sub">We work across the full spectrum &mdash; mind, body, and nervous system &mdash; because lasting change lives in all three at once.</p>
  </PageHero>

  <Fragment set:html={wellnessSection} />
</BaseLayout>
